---
const categories = [
  {
    name: "Management",
    tools: ["Discord", "Notion", "Google Workspace"],
  },
  {
    name: "No Code",
    tools: ["Figma", "Framer", "n8n", "GHL"],
  },
  {
    name: "DevOps & Cloud",
    tools: ["Git", "Github Actions", "Supabase", "Vercel"],
  },
  {
    name: "Frontend",
    tools: ["JavaScript", "TypeScript", "React", "Vue.js", "Vite", "Tailwind CSS", "React Native", "Expo"],
  },
  {
    name: "Backend",
    tools: ["Java", "Python", "Node.js", "Express.js", "REST", "MySQL", "MariaDB"],
  },
];
---

<section class="min-h-screen w-full flex items-center" id="stack">
  <div class="container-page w-full py-20">
    <p class="text-[11px] font-normal text-muted tracking-widest uppercase mb-10">Tech Stack</p>
    <h2 class="font-serif mb-12" style="font-size: clamp(28px, 4vw, 42px);">What I work with</h2>

    <div class="flex flex-col gap-0">
      {categories.map((cat, i) => (
        <div class={`grid gap-5 items-start py-8 ${i < categories.length - 1 ? 'border-b border-gray-100' : ''}`}
             style="grid-template-columns: 160px 1fr;">
          <p class="text-[11px] font-normal text-muted tracking-widest uppercase pt-1.5">
            {cat.name}
          </p>
          <div class="flex flex-wrap gap-2">
            {cat.tools.map((tool) => (
              <span class="pill">{tool}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
